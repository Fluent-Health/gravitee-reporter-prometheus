<configuration>
  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
    </encoder>
  </appender>

  <root level="INFO">
    <appender-ref ref="STDOUT" />
  </root>

  <!-- Suppress verbose Testcontainers and Docker logs -->
  <logger name="org.testcontainers" level="WARN" />
  <logger name="com.github.dockerjava" level="WARN" />
  <logger name="org.testcontainers.shaded" level="WARN" />

  <!-- Suppress container logs unless needed for debugging -->
  <logger name="tc.management-api" level="WARN" />
  <logger name="tc.httpbin" level="WARN" />
  <logger name="tc.gateway" level="WARN" />
</configuration>
